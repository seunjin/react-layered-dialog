{
  "name": "react-layered-dialog",
  "version": "1.0.0",
  "description": "A flexible and layered dialog component for React",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "pnpm run build -- --watch",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "5 kB"
    },
    {
      "path": "dist/index.js",
      "limit": "6 kB"
    }
  ],
  "keywords": [
    "react",
    "dialog",
    "modal",
    "layered"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "size-limit": "^12.0.1"
  },
  "dependencies": {
    "use-sync-external-store": "^1.5.0"
  }
}